FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /workspace
COPY backend/rule-engine-service ./backend/rule-engine-service
WORKDIR /workspace/backend/rule-engine-service
RUN mvn -q -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
COPY --from=build /workspace/backend/rule-engine-service/rule-engine-start/target/rule-engine-start-0.1.0-SNAPSHOT.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
