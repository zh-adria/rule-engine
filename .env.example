# ============================================
# 规则引擎平台 - 本地开发环境变量
# 复制此文件为 .env 并填入实际值
# .env 已加入 .gitignore，不会被提交
# ============================================

# Jasypt 解密密码（必须！用于解密 application.yml 中的 ENC(...) 配置）
JASYPT_ENCRYPTOR_PASSWORD=

# MySQL 连接覆盖值必须使用 ENC(...)，禁止写明文 URL / 用户名 / 密码
MYSQL_URL=
MYSQL_USER=
MYSQL_PASSWORD=

# 敏感规则 AES 加密密钥（32 字符）
RULE_ENGINE_AES_KEY=

# 审批回调密钥
APPROVAL_CALLBACK_SECRET=

# Sa-Token 认证（本地脚本/Compose 提供下列默认值；生产请覆盖）
SA_TOKEN_JWT_SECRET_KEY=rule-engine-sa-token-jwt-secret-2026
RULE_ENGINE_ADMIN_USERNAME=admin
RULE_ENGINE_ADMIN_PASSWORD=admin123
RULE_ENGINE_TESTER_USERNAME=underwriter
RULE_ENGINE_TESTER_PASSWORD=underwriter123

